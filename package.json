{
	"name": "n8n-nodes-leanvox",
	"version": "0.1.1",
	"description": "n8n community node for LeanVox TTS & STT API",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"leanvox",
		"tts",
		"stt",
		"text-to-speech",
		"speech-to-text",
		"transcription"
	],
	"license": "MIT",
	"homepage": "",
	"author": {
		"name": "LeanVox"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/leanvox/n8n-nodes-leanvox.git"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "tsc --noEmit",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/LeanvoxApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Leanvox/Leanvox.node.js"
		]
	},
	"devDependencies": {
		"@types/node": "^20.11.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "^1.27.0",
		"typescript": "^5.3.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
